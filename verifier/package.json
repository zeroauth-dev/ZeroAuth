    "better-sqlite3": "^12.10.0",
    "express": "^4.18.2",
    "snarkjs": "^0.7.6",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/snarkjs": "^0.7.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "jest": "^30.4.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.0",
    "typescript": "^5.3.3"
  }
