# ZeroAuth — production template for zeroauth.dev
# Copy to .env on the production host and fill in the marked values.
# Do NOT commit the filled-in version. .env is gitignored.

# ───────────────────────── Server ─────────────────────────
NODE_ENV=production
PORT=3000
API_BASE_URL=https://zeroauth.dev
CORS_ORIGINS=https://zeroauth.dev,https://www.zeroauth.dev
TRUST_PROXY=true

# Demo SAML/OIDC routes (no real signature validation). Keep disabled in prod.
ENABLE_DEMO_AUTH=false

# ────────────────────────── JWT ───────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=__ROTATE_ME__
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────── SAML 2.0 / OIDC ────────────────────
# Configure these only if onboarding enterprise customers; safe to leave blank
# at launch.
SAML_ENTRY_POINT=https://idp.example.com/sso/saml
SAML_ISSUER=zeroauth-sp
SAML_CALLBACK_URL=https://zeroauth.dev/api/auth/saml/callback
SAML_CERT=

OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://zeroauth.dev/api/auth/oidc/callback

# ──────────────────────── Session ─────────────────────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=__ROTATE_ME__

# ─────────────────────── Rate Limiting ────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ──────────────────────── Admin Key ───────────────────────
# Generate with: openssl rand -hex 24
ADMIN_API_KEY=__ROTATE_ME__

# ─────────────────────── Logging ──────────────────────────
LOG_LEVEL=info

# ────────────────── Blockchain (Base Sepolia L2) ──────────
# This deployer wallet must own DIDRegistry. Either:
#   (a) reuse the original deployer key (paste hex below), OR
#   (b) generate a new wallet and run scripts/transfer-ownership.ts FIRST
#       using the OLD key, then paste the NEW key here.
BLOCKCHAIN_RPC_URL=https://sepolia.base.org
BLOCKCHAIN_CHAIN_ID=84532
BLOCKCHAIN_PRIVATE_KEY=__SET_ME__
DID_REGISTRY_ADDRESS=0xC68ceB726DDB898E899080021A0B9e7994f63A73
VERIFIER_CONTRACT_ADDRESS=0x58258bf549D8E8694b22B12410F24583D16e1aA4
VERIFY_ON_CHAIN=false

# ─────────────────── ZKP Circuit Paths ────────────────────
ZKP_WASM_PATH=circuits/build/identity_proof_js/identity_proof.wasm
ZKP_ZKEY_PATH=circuits/build/circuit_final.zkey
ZKP_VKEY_PATH=circuits/build/verification_key.json

# ─────────────────── Redis (sessions) ─────────────────────
REDIS_URL=redis://redis:6379
USE_REDIS_SESSIONS=true

# ──────────────────────── PostgreSQL ──────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zeroauth
POSTGRES_USER=zeroauth
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=__ROTATE_ME__
